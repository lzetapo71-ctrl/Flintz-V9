local function lanzarGolpe()
    if tick() - lastM1Time < 0.15 then return end 
    lastM1Time = tick()
    
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then tool:Activate() end
	inputEvent:FireServer("M1")
end

