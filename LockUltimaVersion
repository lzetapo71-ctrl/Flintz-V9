    character = char; rootPart = char:WaitForChild("HumanoidRootPart"); humanoid = char:WaitForChild("Humanoid")
    forwardTrackS2 = loadAnim("rbxassetid://18783040383"); clearLockS1(); setupDetection(humanoid)
end)

