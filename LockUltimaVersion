--// VARIABLES SCRIPT 2 (DASH SUAVE)
-------------------------------------------------------------------
local dashForceGround = 140      
local dashForceAir = 115         
local dashDurationDefault = 0.35 
local rotationSmoothnessS2 = 0.25 
local cooldownDurationS2 = 1.1
