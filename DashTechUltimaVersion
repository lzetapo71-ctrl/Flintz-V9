--// CACHE DE ANIMACIONES
local function loadAnim(id)
    local a = Instance.new("Animation")
    a.AnimationId = id
    return humanoid:LoadAnimation(a)
end
local forwardTrack = loadAnim("rbxassetid://18783040383")

--// FUNCIONES NÚCLEO (OPTIMIZADAS)
local function lanzarGolpe()
    -- Evita que el ping suba y que el juego bloquee los ataques por spam de remotos
    if tick() - lastM1Time < 0.18 then return end 
    lastM1Time = tick()
    
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then tool:Activate() end
    inputEvent:FireServer("M1")
end

-- Dash de Retroceso (Backdash)
local function applyBackDash(distance)
    if isDashing then return end
    isDashing = true
    forwardTrack:Play()
    
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e6, 0, 1e6)
    bv.Parent = rootPart
    
    local dir = -rootPart.CFrame.LookVector 
    bv.Velocity = dir * (distance * 12) 
    
    task.wait(0.15)
    bv:Destroy()
    isDashing = false
end

-- Dash Físico
local function applyPhysicalDash(force, duration)
    if isDashing then return end
    isDashing = true
    forwardTrack:Play()
    lanzarGolpe()
    
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bv.Parent = rootPart
    
    local dir = (humanoid.MoveDirection.Magnitude > 0.1) and humanoid.MoveDirection or rootPart.CFrame.LookVector

    local start = os.clock()
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if os.clock() - start < duration and humanoid.Health > 0 then
            bv.Velocity = dir * force
            rootPart.CFrame = rootPart.CFrame:Lerp(CFrame.new(rootPart.Position, rootPart.Position + dir), 0.15)
        else
            bv:Destroy(); conn:Disconnect(); isDashing = false
        end
    end)
end

-- Dash Suave
local function applySmoothDash(force, duration)
    if isDashing then return end
    isDashing = true
    forwardTrack:Play()
    lanzarGolpe()
    
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bv.Parent = rootPart
    
    local start = os.clock()
    local dir = (humanoid.MoveDirection.Magnitude > 0.1) and humanoid.MoveDirection or rootPart.CFrame.LookVector
    
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if os.clock() - start < duration and humanoid.Health > 0 then
            bv.Velocity = dir * force
            rootPart.CFrame = rootPart.CFrame:Lerp(CFrame.lookAt(rootPart.Position, rootPart.Position + dir), 0.25)
        else
            bv:Destroy(); conn:Disconnect(); isDashing = false
        end
    end)
end

local function executeGoAction()
    if isDashing or humanoid.Health <= 0 then return end
    local inAir = (humanoid.FloorMaterial == Enum.Material.Air)
    local force = inAir and dashForceS1Air or dashForceS1
    local duration = inAir and dashDurationS1Air or dashDurationS1
    
    if script1Available then
        script1Available = false
        inputEvent:FireServer("Dash", false)
        applyPhysicalDash(force, duration)
    elseif os.clock() - lastGoTimeS2 >= cooldownS2 then
        lastGoTimeS2 = os.clock()
        inputEvent:FireServer("Dash", false)
        applySmoothDash(force, duration)
    end
end

