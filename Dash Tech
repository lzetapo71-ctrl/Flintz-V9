-- FUNCIÓN MOVIMIENTO LOOP
local function performLoopMovement()
    if not isActive then return end
    local startCFrame = rootPart.CFrame
    local steps, radius, forwardAdvance = 20, 5, 4
    task.spawn(function()
        for i = 1, steps do
            local angle = math.rad((i / steps) * 360)
            local xOffset = math.sin(angle) * radius
            local zOffset = (math.cos(angle) * -radius) + radius
            local progressForward = (i / steps) * forwardAdvance
            rootPart.CFrame = startCFrame * CFrame.new(xOffset, 0, -zOffset - progressForward) * CFrame.Angles(0, angle, 0)
            task.wait(0.01)
        end
        rootPart.CFrame = startCFrame * CFrame.new(0, 0, -forwardAdvance)
    end)
end

-- FUNCIÓN DASH FÍSICO
local function applyPhysicalDash(selectedTrack)
    selectedTrack:Play()
    local velocity = Instance.new("BodyVelocity")
    velocity.MaxForce = Vector3.new(1, 1, 1) * 50000 
    velocity.Parent = rootPart
    local dashDirection = humanoid.MoveDirection
    if dashDirection.Magnitude < 0.1 then dashDirection = rootPart.CFrame.LookVector end
    local startTime = tick()
    local connection
    connection = runService.RenderStepped:Connect(function()
        if tick() - startTime < dashDuration then
            for _, v in pairs(workspace:GetChildren()) do
                if v:IsA("Model") and v ~= character and v:FindFirstChild("Humanoid") then
                    for _, part in pairs(v:GetChildren()) do
                        if part:IsA("BasePart") then part.CanCollide = false end
                    end
                end
            end
            if humanoid.MoveDirection.Magnitude > 0.1 then dashDirection = humanoid.MoveDirection end
            velocity.Velocity = dashDirection * dashForce
            local targetCFrame = CFrame.new(rootPart.Position, rootPart.Position + dashDirection)
            rootPart.CFrame = rootPart.CFrame:Lerp(targetCFrame, rotationSmoothness)
        else
            velocity:Destroy()
            connection:Disconnect()
        end
    end)
end

-- COOLDOWN VISUAL
local function startCooldown()
    if cooldownThread then task.cancel(cooldownThread) end 
    isOnCooldown = true
    GoButton.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    cooldownThread = task.spawn(function()
        local timeLeft = specialCooldown
        while timeLeft > 0 do
            GoButton.Text = string.format("%.1fs", timeLeft)
            task.wait(0.1)
            timeLeft = timeLeft - 0.1
        end
        GoButton.Text = "Go"
        GoButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        isOnCooldown = false
    end)
end

-- EJECUCIÓN DASH (GO)
local function executeDashLogic()
    if isOnCooldown then return end
    character = player.Character or player.CharacterAdded:Wait()
    rootPart = character:WaitForChild("HumanoidRootPart")
    humanoid = character:WaitForChild("Humanoid")
    local inputRemote = replicatedStorage:WaitForChild("Events"):WaitForChild("Input")
    startCooldown()
    inputRemote:FireServer("Dash", false)
    inputRemote:FireServer("M1")
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then tool:Activate() end
    task.wait(0.02)
    applyPhysicalDash(forwardTrack)
end

GoButton.MouseButton1Click:Connect(executeDashLogic)

